rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Allow users to read and write their own base user document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subscription Subcollection: Strictly Read-Only
      match /subscription/{document=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only Admin SDK can write
      }
      
      // Usage Subcollection: Strictly Read-Only 
      // (Metrics managed by Firebase Functions/Server to prevent client-side infinite spoofing)
      match /usage/{document=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only Admin SDK can write
      }
    }

    // API Keys — Server-only. No client reads or writes.
    // Keys are hashed before storage; raw keys are never persisted.
    match /api_keys/{keyId} {
      allow read, write: if false; // Only Admin SDK (server-side) can access
    }

    // Certificates — Server writes, public reads by doc ID
    match /certificates/{certId} {
      allow read: if true;         // Anyone can verify a certificate by its ID
      allow write: if false;       // Only Admin SDK can create certificates
    }
  }
}

