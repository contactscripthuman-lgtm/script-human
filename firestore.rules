rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow users to read and write their own documents
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subscription documents
      match /subscription/{document=**} {
        // Users can read their own subscription documents
        allow read: if request.auth != null && request.auth.uid == userId;
        
        // ONLY the backend (Admin SDK via Stripe Webhook) can write these documents
        allow write: if false;
      }
      
      // Usage documents
      match /usage/{document=**} {
        // Users can read their own usage tracker
        allow read: if request.auth != null && request.auth.uid == userId;
        // For securely incrementing limits, writing should ideally be restricted to cloud functions, 
        // but allowing it securely here for client-side tracking functionality if implemented.
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
