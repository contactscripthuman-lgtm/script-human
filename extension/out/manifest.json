{
  "manifest_version": 3,
  "name": "ScriptHuman - #1 AI Content Humanizer Tool.",
  "version": "1.0.0",
  "description": "Humanize text directly in your browser. Bypasses AI Detectors like Turnitin, GPTZero & ZeroGPT.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite",
    "contextMenus"
  ],
  "host_permissions": [
    "https://*.scripthuman.com/*",
    "https://scripthuman.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open ScriptHuman",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*.scripthuman.com/*",
        "https://scripthuman.com/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "sync.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
